---
import type { GetStaticPaths } from "astro";
import BaseLayout from "../../layouts/BaseLayout.astro";
import CertificationsContent from "../../components/CertificationsContent.astro";
import { sortedCertifications } from "../../data";

export const getStaticPaths = (({ paginate }) =>
  paginate(sortedCertifications, { pageSize: 9 })) satisfies GetStaticPaths;

const { page } = Astro.props;
---

<BaseLayout
  title="Certificaciones · Miguel Ángel Delgado"
  description="Formación continua, cursos y credenciales en desarrollo de software."
>
  <CertificationsContent page={page} base="/certificaciones" />
</BaseLayout>
