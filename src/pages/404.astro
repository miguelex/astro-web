---
import BaseLayout from "../layouts/BaseLayout.astro";
---

<BaseLayout
  title="404 · Página no encontrada"
  description="La página que buscas no existe."
  noindex={true}
>
  <section class="relative mx-auto flex max-w-2xl flex-col items-center px-5 py-36 text-center">
    <div class="glow-spot pointer-events-none absolute inset-0 -z-10 [mask-image:radial-gradient(closest-side,black,transparent)]"></div>
    <p class="font-display text-8xl font-light text-gradient">404</p>
    <h1 class="mt-4 font-display text-3xl font-light tracking-tight">
      Página no encontrada
    </h1>
    <p class="mt-3 text-[var(--fg-muted)]">
      Lo siento, la página que buscas no existe o ha sido movida.
    </p>
    <a
      href="/"
      class="mt-8 inline-flex items-center gap-2 rounded-xl bg-[var(--brand)] px-5 py-3 text-sm font-semibold text-[var(--brand-fg)] shadow-[var(--shadow)] transition-transform hover:-translate-y-0.5"
    >
      ← Volver al inicio
    </a>
  </section>
</BaseLayout>
