---
import { getCollection, render } from "astro:content";
import BaseLayout from "../../layouts/BaseLayout.astro";
import BlogArticle from "../../components/BlogArticle.astro";
import { postSlug } from "../../lib/blog";

export async function getStaticPaths() {
  const posts = await getCollection("blog", ({ data }) => {
    const visible = import.meta.env.PROD ? !data.draft : true;
    return data.lang === "es" && visible;
  });
  return posts.map((post) => ({
    params: { slug: postSlug(post.id) },
    props: { post },
  }));
}

const { post } = Astro.props;
const { Content } = await render(post);
---

<BaseLayout title={`${post.data.title} · Blog`} description={post.data.description} type="article">
  <BlogArticle post={post}>
    <Content />
  </BlogArticle>
</BaseLayout>
