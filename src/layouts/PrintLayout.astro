---
/**
 * Layout autónomo para el documento PDF del CV.
 * Sin cabecera/pie del sitio ni tema oscuro: una hoja A4 limpia, en negro sobre
 * blanco, optimizada para ATS (una columna, texto real, jerarquía semántica).
 * Se renderiza a PDF con Playwright (scripts/generate-cv-pdf.mjs).
 */
interface Props {
  title: string;
  lang: "es" | "en";
}
const { title, lang } = Astro.props;
---

<!doctype html>
<html lang={lang}>
  <head>
    <meta charset="UTF-8" />
    <meta name="robots" content="noindex, nofollow" />
    <title>{title}</title>
    <style is:global>
      @page {
        size: A4;
        margin: 10mm 15mm;
      }
      * {
        box-sizing: border-box;
        margin: 0;
        padding: 0;
      }
      html {
        font-family: "Geist Variable", -apple-system, "Segoe UI", Arial, sans-serif;
        font-size: 10pt;
        line-height: 1.4;
        color: #111;
        background: #fff;
        -webkit-print-color-adjust: exact;
        print-color-adjust: exact;
      }
      body {
        max-width: 180mm;
        margin: 0 auto;
        padding: 0;
      }
      a {
        color: #111;
        text-decoration: none;
      }
      h1 {
        font-size: 22pt;
        font-weight: 600;
        letter-spacing: -0.01em;
      }
      .role {
        font-size: 11.5pt;
        color: #444;
        margin-top: 2pt;
      }
      .contact {
        margin-top: 6pt;
        font-size: 9.5pt;
        color: #333;
        display: flex;
        flex-wrap: wrap;
        gap: 4pt 14pt;
      }
      .contact a {
        display: inline-flex;
        align-items: center;
        gap: 4pt;
      }
      .contact svg {
        width: 10pt;
        height: 10pt;
        fill: #555;
        flex-shrink: 0;
      }
      hr {
        border: none;
        border-top: 0.75pt solid #c9a227;
        margin: 8pt 0;
      }
      /* Sin letter-spacing: un tracking amplio hace que el ATS lea los títulos
         troceados letra a letra ("E X P E R I E N C I A") y no detecte las
         secciones. Se mantiene el look con mayúsculas, color y borde. */
      h2 {
        font-size: 9.5pt;
        text-transform: uppercase;
        letter-spacing: normal;
        color: #8a6d1b;
        margin: 8pt 0 5pt;
        border-bottom: 0.5pt solid #ddd;
        padding-bottom: 3pt;
      }
      .summary {
        color: #333;
      }
      .item {
        margin-bottom: 6pt;
        page-break-inside: avoid;
      }
      .item-head {
        display: flex;
        justify-content: space-between;
        align-items: baseline;
        gap: 10pt;
      }
      .item-title {
        font-weight: 600;
        font-size: 10.5pt;
      }
      .item-org {
        font-weight: 400;
        color: #555;
      }
      .item-date {
        font-size: 9pt;
        color: #777;
        white-space: nowrap;
        font-variant-numeric: tabular-nums;
      }
      .item-desc {
        color: #444;
        margin-top: 2pt;
      }
      /* Marcadores en flujo normal (sin position:absolute) para que el ATS
         lea cada logro DENTRO de su empleo y en orden. */
      ul.bullets {
        margin-top: 3pt;
        padding-left: 13pt;
        list-style-position: outside;
        list-style-type: "›  ";
      }
      ul.bullets li {
        color: #333;
        margin-top: 1.5pt;
        padding-left: 2pt;
      }
      ul.bullets li::marker {
        color: #c9a227;
        font-weight: 700;
      }
      .skills-grid {
        display: grid;
        grid-template-columns: 1fr 1fr;
        gap: 6pt 22pt;
      }
      .skill-cat {
        font-weight: 600;
        font-size: 9.5pt;
      }
      .skill-items {
        color: #444;
        font-size: 9.5pt;
      }
      .edu-row {
        display: flex;
        justify-content: space-between;
        gap: 10pt;
        margin-bottom: 3pt;
      }
    </style>
  </head>
  <body>
    <slot />
  </body>
</html>
