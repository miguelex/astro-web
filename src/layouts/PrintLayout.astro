---
/**
 * Layout autónomo para el documento PDF del CV.
 * Sin cabecera/pie del sitio ni tema oscuro: una hoja A4 limpia, en negro sobre
 * blanco, optimizada para ATS (una columna, texto real, jerarquía semántica).
 * Se renderiza a PDF con Playwright (scripts/generate-cv-pdf.mjs).
 */
interface Props {
  title: string;
  lang: "es" | "en";
}
const { title, lang } = Astro.props;
---

<!doctype html>
<html lang={lang}>
  <head>
    <meta charset="UTF-8" />
    <meta name="robots" content="noindex, nofollow" />
    <title>{title}</title>
    <style is:global>
      @page {
        size: A4;
        margin: 16mm 16mm;
      }
      * {
        box-sizing: border-box;
        margin: 0;
        padding: 0;
      }
      html {
        font-family: "Geist Variable", -apple-system, "Segoe UI", Arial, sans-serif;
        font-size: 10.5pt;
        line-height: 1.45;
        color: #111;
        background: #fff;
        -webkit-print-color-adjust: exact;
        print-color-adjust: exact;
      }
      body {
        max-width: 178mm;
        margin: 0 auto;
        padding: 10mm 0;
      }
      a {
        color: #111;
        text-decoration: none;
      }
      h1 {
        font-size: 22pt;
        font-weight: 600;
        letter-spacing: -0.01em;
      }
      .role {
        font-size: 11.5pt;
        color: #444;
        margin-top: 2pt;
      }
      .contact {
        margin-top: 6pt;
        font-size: 9.5pt;
        color: #333;
        display: flex;
        flex-wrap: wrap;
        gap: 4pt 14pt;
      }
      .contact span::before {
        content: "";
      }
      hr {
        border: none;
        border-top: 0.75pt solid #c9a227;
        margin: 10pt 0;
      }
      h2 {
        font-size: 10pt;
        text-transform: uppercase;
        letter-spacing: 0.12em;
        color: #8a6d1b;
        margin: 14pt 0 7pt;
        border-bottom: 0.5pt solid #ddd;
        padding-bottom: 3pt;
      }
      .summary {
        color: #333;
      }
      .item {
        margin-bottom: 9pt;
        page-break-inside: avoid;
      }
      .item-head {
        display: flex;
        justify-content: space-between;
        align-items: baseline;
        gap: 10pt;
      }
      .item-title {
        font-weight: 600;
        font-size: 10.5pt;
      }
      .item-org {
        font-weight: 400;
        color: #555;
      }
      .item-date {
        font-size: 9pt;
        color: #777;
        white-space: nowrap;
        font-variant-numeric: tabular-nums;
      }
      .item-desc {
        color: #444;
        margin-top: 2pt;
      }
      ul.bullets {
        margin-top: 3pt;
        padding-left: 14pt;
        list-style: none;
      }
      ul.bullets li {
        position: relative;
        color: #333;
        margin-top: 1.5pt;
      }
      ul.bullets li::before {
        content: "›";
        position: absolute;
        left: -11pt;
        color: #c9a227;
        font-weight: 700;
      }
      .skills-grid {
        display: grid;
        grid-template-columns: 1fr 1fr;
        gap: 6pt 22pt;
      }
      .skill-cat {
        font-weight: 600;
        font-size: 9.5pt;
      }
      .skill-items {
        color: #444;
        font-size: 9.5pt;
      }
      .edu-row {
        display: flex;
        justify-content: space-between;
        gap: 10pt;
        margin-bottom: 3pt;
      }
    </style>
  </head>
  <body>
    <slot />
  </body>
</html>
