---
import PageHeader from "./PageHeader.astro";
import { sortedCertifications } from "../data";
import { getLangFromUrl, useTranslations } from "../i18n/utils";
import { issuerStyle } from "../lib/issuers";
import { techIconPath } from "../lib/techIcons";
const lang = getLangFromUrl(Astro.url);
const t = useTranslations(lang);

const fmt = (d: string) =>
  new Date(d + "-01").toLocaleDateString(lang === "es" ? "es-ES" : "en-US", {
    month: "short",
    year: "numeric",
  });
---

<PageHeader title={t("certifications.title")} subtitle={t("certifications.subtitle")} kicker={t("kicker.learning")} />

<div class="mx-auto max-w-5xl px-5 py-16">
  <ul class="grid gap-6 sm:grid-cols-2">
    {
      sortedCertifications.map((cert) => {
        const is = issuerStyle(cert.issuer);
        return (
          <li
            class="reveal group flex flex-col overflow-hidden rounded-2xl border border-[var(--border)] bg-[var(--bg-card)] transition-all duration-300 hover:-translate-y-1.5 hover:border-[color-mix(in_srgb,var(--issuer)_50%,transparent)] hover:shadow-[var(--shadow)]"
            style={`--issuer:${is.color}`}
          >
            {/* Cabecera: imagen real si existe, si no banner generado con el emisor */}
            {cert.image ? (
              <div class="relative aspect-[16/7] overflow-hidden border-b border-[var(--border)]">
                <img
                  src={cert.image}
                  alt={cert.title}
                  loading="lazy"
                  decoding="async"
                  class="size-full object-cover transition-transform duration-700 group-hover:scale-105"
                />
              </div>
            ) : (
              <div
                class="relative flex aspect-[16/7] items-center justify-center overflow-hidden border-b border-[var(--border)]"
                style="background: radial-gradient(120% 140% at 15% 10%, color-mix(in srgb, var(--issuer) 35%, transparent), transparent 60%), linear-gradient(135deg, color-mix(in srgb, var(--issuer) 18%, var(--bg-card)), var(--bg-card))"
              >
                {/* patrón de puntos */}
                <div
                  class="absolute inset-0 opacity-[0.5]"
                  style="background-image: radial-gradient(color-mix(in srgb, var(--issuer) 30%, transparent) 1px, transparent 1px); background-size: 16px 16px; mask-image: linear-gradient(135deg, black, transparent 70%)"
                />
                {/* logo del emisor (o inicial) */}
                {is.iconPath ? (
                  <svg class="size-16 opacity-90 transition-transform duration-500 group-hover:scale-110" viewBox="0 0 24 24" fill="currentColor" style="color: var(--issuer)" aria-hidden="true">
                    <path d={is.iconPath} />
                  </svg>
                ) : (
                  <span class="font-display text-5xl font-semibold transition-transform duration-500 group-hover:scale-110" style="color: var(--issuer)">
                    {cert.issuer.charAt(0)}
                  </span>
                )}
                <span
                  class="absolute bottom-3 left-4 rounded-md border px-2 py-0.5 font-mono text-[11px] font-medium backdrop-blur-sm"
                  style="color: var(--issuer); border-color: color-mix(in srgb, var(--issuer) 35%, transparent); background: color-mix(in srgb, var(--issuer) 12%, var(--bg-card))"
                >
                  {cert.issuer}
                </span>
              </div>
            )}

            <div class="flex flex-1 flex-col p-5">
              <span class="font-mono text-xs text-[var(--fg-subtle)]">{fmt(cert.date)}</span>
              <h2 class="mt-1.5 font-display text-lg font-medium leading-snug">{cert.title}</h2>

              {cert.tech && (
                <ul class="mt-3 flex flex-wrap gap-1.5">
                  {cert.tech.map((tag) => {
                    const iconPath = techIconPath(tag);
                    return (
                      <li class="inline-flex items-center gap-1.5 rounded-md border border-[var(--border)] bg-[var(--bg-subtle)] px-2 py-0.5 font-mono text-[11px] text-[var(--fg-muted)]">
                        {iconPath && (
                          <svg class="size-3 shrink-0 opacity-80" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
                            <path d={iconPath} />
                          </svg>
                        )}
                        {tag}
                      </li>
                    );
                  })}
                </ul>
              )}

              {cert.url && (
                <a
                  href={cert.url}
                  target="_blank"
                  rel="noopener noreferrer"
                  class="mt-4 inline-flex items-center gap-1.5 self-start border-t border-transparent pt-1 text-sm font-semibold text-[var(--brand)] transition-colors hover:underline"
                >
                  {t("certifications.verify")}
                  <svg class="size-3.5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                    <path d="M7 17L17 7M7 7h10v10" />
                  </svg>
                </a>
              )}
            </div>
          </li>
        );
      })
    }
  </ul>
</div>
