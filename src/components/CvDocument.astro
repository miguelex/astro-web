---
import { profile, skills, experience, education } from "../data";
import { useTranslations, tField } from "../i18n/utils";
import type { Lang, UIKey } from "../i18n/ui";

interface Props {
  lang: Lang;
}
const { lang } = Astro.props;
const t = useTranslations(lang);

const labelKey: Record<string, UIKey> = {
  tech: "section.skills.tech",
  tools: "section.skills.tools",
  databases: "section.skills.databases",
  soft: "section.skills.soft",
};
// LinkedIn/GitHub en texto plano legible para ATS
const cleanUrl = (u: string) => u.replace(/^https?:\/\/(www\.)?/, "");
---

<header>
  <h1>{profile.name}</h1>
  <div class="role">{tField(profile.role, lang)}</div>
  <div class="contact">
    <a href={`mailto:${profile.email}`}>{profile.email}</a>
    <span>{tField(profile.location, lang)}</span>
    <a href={profile.social.linkedin}>
      <svg viewBox="0 0 24 24" aria-hidden="true"><path d="M20.447 20.452h-3.554v-5.569c0-1.328-.027-3.037-1.852-3.037-1.853 0-2.136 1.445-2.136 2.939v5.667H9.351V9h3.414v1.561h.046c.477-.9 1.637-1.85 3.37-1.85 3.601 0 4.267 2.37 4.267 5.455v6.286zM5.337 7.433c-1.144 0-2.063-.926-2.063-2.065 0-1.138.92-2.063 2.063-2.063 1.14 0 2.064.925 2.064 2.063 0 1.139-.925 2.065-2.064 2.065zm1.782 13.019H3.555V9h3.564v11.452zM22.225 0H1.771C.792 0 0 .774 0 1.729v20.542C0 23.227.792 24 1.771 24h20.451C23.2 24 24 23.227 24 22.271V1.729C24 .774 23.2 0 22.222 0h.003z"/></svg>
      {cleanUrl(profile.social.linkedin)}
    </a>
    <a href={profile.social.github}>
      <svg viewBox="0 0 24 24" aria-hidden="true"><path d="M12 .297c-6.63 0-12 5.373-12 12 0 5.303 3.438 9.8 8.205 11.385.6.113.82-.258.82-.577 0-.285-.01-1.04-.015-2.04-3.338.724-4.042-1.61-4.042-1.61C4.422 18.07 3.633 17.7 3.633 17.7c-1.087-.744.084-.729.084-.729 1.205.084 1.838 1.236 1.838 1.236 1.07 1.835 2.809 1.305 3.495.998.108-.776.417-1.305.76-1.605-2.665-.305-5.467-1.334-5.467-5.931 0-1.311.469-2.381 1.236-3.221-.124-.303-.535-1.524.117-3.176 0 0 1.008-.322 3.301 1.23A11.509 11.509 0 0112 5.803c1.02.005 2.047.138 3.006.404 2.291-1.552 3.297-1.23 3.297-1.23.653 1.653.242 2.874.118 3.176.77.84 1.235 1.911 1.235 3.221 0 4.609-2.807 5.624-5.479 5.921.43.372.823 1.102.823 2.222 0 1.606-.014 2.898-.014 3.293 0 .322.216.694.825.576C20.565 22.092 24 17.592 24 12.297c0-6.627-5.373-12-12-12"/></svg>
      {cleanUrl(profile.social.github)}
    </a>
  </div>
</header>
<hr />

<section>
  <h2>{lang === "es" ? "Perfil profesional" : "Professional summary"}</h2>
  <p class="summary">{tField(profile.summary, lang)}</p>
</section>

<section>
  <h2>{t("section.experience")}</h2>
  {
    experience.map((job) => (
      <div class="item">
        <div class="item-head">
          <div class="item-title">
            {tField(job.role, lang)} <span class="item-org">· {job.company}</span>
          </div>
          <div class="item-date">
            {job.start} – {job.end ?? t("present")}
          </div>
        </div>
        <div class="item-desc">{tField(job.description, lang)}</div>
        <ul class="bullets">
          {tField(job.highlights, lang).map((h) => (
            <li>{h}</li>
          ))}
        </ul>
        <div class="item-desc" style="margin-top:3pt;font-size:9pt;color:#666;">
          {job.tech.join(" · ")}
        </div>
      </div>
    ))
  }
</section>

<section>
  <h2>{t("section.education")}</h2>
  {
    education.map((edu) => (
      <div class="edu-row">
        <div>
          <span class="item-title">{tField(edu.degree, lang)}</span>
          <span class="item-org"> · {edu.institution}</span>
        </div>
        <div class="item-date">
          {edu.start} – {edu.end}
        </div>
      </div>
    ))
  }
</section>

<section>
  <h2>{t("section.skills")}</h2>
  <div class="skills-grid">
    {
      skills.map((group) => (
        <div>
          <div class="skill-cat">{t(labelKey[group.category])}</div>
          <div class="skill-items">{group.items.join(", ")}</div>
        </div>
      ))
    }
  </div>
</section>
