---
import { profile, skills, experience, education } from "../data";
import { getLangFromUrl, useTranslations, tField } from "../i18n/utils";
import type { UIKey } from "../i18n/ui";
const lang = getLangFromUrl(Astro.url);
const t = useTranslations(lang);

const labelKey: Record<string, UIKey> = {
  tech: "section.skills.tech",
  tools: "section.skills.tools",
  databases: "section.skills.databases",
  soft: "section.skills.soft",
};
---

<div class="cv-sheet mx-auto max-w-3xl px-5 py-12">
  <!-- Barra de acciones (no se imprime) -->
  <div class="no-print mb-8 flex justify-end">
    <button
      id="cv-print"
      type="button"
      class="inline-flex items-center gap-2 rounded-xl bg-[var(--brand)] px-5 py-2.5 text-sm font-semibold text-[var(--brand-fg)] transition-transform hover:-translate-y-0.5"
    >
      <svg class="size-4" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
        <path d="M6 9V2h12v7M6 18H4a2 2 0 0 1-2-2v-5a2 2 0 0 1 2-2h16a2 2 0 0 1 2 2v5a2 2 0 0 1-2 2h-2M6 14h12v8H6z"></path>
      </svg>
      {t("cv.print")}
    </button>
  </div>

  <!-- Cabecera -->
  <header class="border-b border-[var(--border)] pb-6">
    <h1 class="font-display text-3xl font-bold tracking-tight">{profile.name}</h1>
    <p class="mt-1 font-mono text-sm text-[var(--brand)]">{tField(profile.role, lang)}</p>
    <div class="mt-3 flex flex-wrap gap-x-5 gap-y-1 text-sm text-[var(--fg-muted)]">
      <span>{profile.email}</span>
      <span>{tField(profile.location, lang)}</span>
      <a href={profile.social.linkedin} class="hover:text-[var(--brand)]">LinkedIn</a>
      <a href={profile.social.github} class="hover:text-[var(--brand)]">GitHub</a>
    </div>
  </header>

  <!-- Resumen -->
  <section class="mt-6">
    <p class="text-sm leading-relaxed text-[var(--fg-muted)]">{tField(profile.summary, lang)}</p>
  </section>

  <!-- Experiencia -->
  <section class="mt-8">
    <h2 class="mb-4 font-display text-lg font-bold uppercase tracking-wide">
      {t("section.experience")}
    </h2>
    <div class="space-y-5">
      {
        experience.map((job) => (
          <div>
            <div class="flex flex-wrap items-baseline justify-between gap-2">
              <h3 class="font-semibold">
                {tField(job.role, lang)} · <span class="font-normal">{job.company}</span>
              </h3>
              <span class="font-mono text-xs text-[var(--fg-subtle)]">
                {job.start} — {job.end ?? t("present")}
              </span>
            </div>
            <p class="mt-1 text-sm leading-relaxed text-[var(--fg-muted)]">
              {tField(job.description, lang)}
            </p>
            <ul class="mt-1.5 list-disc space-y-0.5 pl-5 text-sm text-[var(--fg-muted)]">
              {tField(job.highlights, lang).map((h) => (
                <li>{h}</li>
              ))}
            </ul>
          </div>
        ))
      }
    </div>
  </section>

  <!-- Formación -->
  <section class="mt-8">
    <h2 class="mb-4 font-display text-lg font-bold uppercase tracking-wide">
      {t("section.education")}
    </h2>
    <div class="space-y-3">
      {
        education.map((edu) => (
          <div class="flex flex-wrap items-baseline justify-between gap-2">
            <h3 class="font-semibold">
              {tField(edu.degree, lang)} · <span class="font-normal">{edu.institution}</span>
            </h3>
            <span class="font-mono text-xs text-[var(--fg-subtle)]">
              {edu.start} — {edu.end}
            </span>
          </div>
        ))
      }
    </div>
  </section>

  <!-- Habilidades -->
  <section class="mt-8">
    <h2 class="mb-4 font-display text-lg font-bold uppercase tracking-wide">
      {t("section.skills")}
    </h2>
    <div class="grid gap-3 sm:grid-cols-2">
      {
        skills.map((group) => (
          <div>
            <h3 class="font-mono text-xs font-semibold uppercase tracking-wider text-[var(--fg-subtle)]">
              {t(labelKey[group.category])}
            </h3>
            <p class="mt-1 text-sm text-[var(--fg-muted)]">{group.items.join(" · ")}</p>
          </div>
        ))
      }
    </div>
  </section>
</div>

<script is:inline>
  document.getElementById("cv-print")?.addEventListener("click", () => window.print());
</script>
