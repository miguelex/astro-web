---
interface Props {
  index: string; // "01"
  title: string;
  id?: string;
  kicker?: string;
}
const { index, title, id, kicker } = Astro.props;
---

<div class="reveal mb-12" id={id}>
  <div class="flex items-center gap-3 font-mono text-xs uppercase tracking-[0.25em] text-[var(--brand)]">
    <span>{index}</span>
    <span class="h-px w-10 bg-gradient-to-r from-[var(--brand)] to-transparent"></span>
    {kicker && <span class="text-[var(--fg-subtle)]">{kicker}</span>}
  </div>
  <h2 class="mt-3 font-display text-4xl font-light tracking-[-0.02em] sm:text-5xl">
    {title}
  </h2>
</div>
