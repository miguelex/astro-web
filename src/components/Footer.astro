---
import Logo from "./Logo.astro";
import { profile } from "../data";
import { getLangFromUrl, useTranslations } from "../i18n/utils";
const lang = getLangFromUrl(Astro.url);
const t = useTranslations(lang);
const year = new Date().getFullYear();
---

<footer class="relative mt-28 overflow-hidden border-t border-[var(--border)] bg-[var(--bg-subtle)]">
  <div class="glow-spot pointer-events-none absolute -bottom-24 left-1/2 -z-10 size-96 -translate-x-1/2 rounded-full opacity-50"></div>
  <div class="mx-auto max-w-5xl px-5 py-12">
    <div class="flex flex-col items-center gap-8 text-center">
      <a href={lang === "es" ? "/" : "/en"} class="flex items-center gap-2.5" aria-label="Inicio">
        <Logo size={30} />
        <span class="font-display text-base font-medium">Miguel <span class="italic text-[var(--brand)]">Delgado</span></span>
      </a>

      <div class="flex items-center gap-3">
        <a
          href={profile.social.github}
          target="_blank"
          rel="noopener noreferrer"
          class="grid size-10 place-items-center rounded-xl border border-[var(--border)] bg-[var(--bg-card)] text-[var(--fg-muted)] transition-colors hover:border-[var(--brand)] hover:text-[var(--brand)]"
          aria-label="GitHub"
        >
          <svg class="size-5" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
            <path d="M12 .5C5.7.5.5 5.7.5 12c0 5.1 3.3 9.4 7.9 10.9.6.1.8-.2.8-.6v-2c-3.2.7-3.9-1.5-3.9-1.5-.5-1.3-1.3-1.7-1.3-1.7-1-.7.1-.7.1-.7 1.2.1 1.8 1.2 1.8 1.2 1 1.8 2.7 1.3 3.4 1 .1-.8.4-1.3.7-1.6-2.6-.3-5.3-1.3-5.3-5.7 0-1.3.5-2.3 1.2-3.1-.1-.3-.5-1.5.1-3.1 0 0 1-.3 3.3 1.2a11.5 11.5 0 0 1 6 0C17.3 4.7 18.3 5 18.3 5c.6 1.6.2 2.8.1 3.1.8.8 1.2 1.8 1.2 3.1 0 4.4-2.7 5.4-5.3 5.7.4.4.8 1.1.8 2.2v3.3c0 .4.2.7.8.6 4.6-1.5 7.9-5.8 7.9-10.9C23.5 5.7 18.3.5 12 .5z"></path>
          </svg>
        </a>
        <a
          href={profile.social.linkedin}
          target="_blank"
          rel="noopener noreferrer"
          class="grid size-10 place-items-center rounded-xl border border-[var(--border)] bg-[var(--bg-card)] text-[var(--fg-muted)] transition-colors hover:border-[var(--brand)] hover:text-[var(--brand)]"
          aria-label="LinkedIn"
        >
          <svg class="size-5" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
            <path d="M20.45 20.45h-3.55v-5.57c0-1.33 0-3.04-1.85-3.04-1.85 0-2.13 1.45-2.13 2.94v5.67H9.35V9h3.41v1.56h.05c.48-.9 1.64-1.85 3.37-1.85 3.6 0 4.27 2.37 4.27 5.46v6.28zM5.34 7.43a2.06 2.06 0 1 1 0-4.12 2.06 2.06 0 0 1 0 4.12zM7.12 20.45H3.56V9h3.56v11.45zM22.22 0H1.77C.79 0 0 .77 0 1.73v20.54C0 23.22.79 24 1.77 24h20.45c.98 0 1.78-.78 1.78-1.73V1.73C24 .77 23.2 0 22.22 0z"></path>
          </svg>
        </a>
      </div>

      <p class="font-mono text-xs text-[var(--fg-subtle)]">
        © {year} {profile.name}. {t("footer.rights")}
      </p>
    </div>
  </div>
</footer>
