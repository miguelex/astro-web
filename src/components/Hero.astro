---
import SocialButtons from "./SocialButtons.astro";
import { getLangFromUrl, useTranslations, tField } from "../i18n/utils";
import { profile } from "../data";
const lang = getLangFromUrl(Astro.url);
const t = useTranslations(lang);
---

<section class="relative overflow-hidden border-b border-[var(--border)]">
  <div class="pointer-events-none absolute inset-0 -z-10 bg-grid [mask-image:radial-gradient(ellipse_70%_60%_at_50%_0%,black,transparent)]"></div>

  <div class="mx-auto grid max-w-5xl items-center gap-14 px-5 py-24 lg:grid-cols-[1.12fr_0.88fr] lg:py-32">
    <div>
      <p class="anim inline-flex items-center gap-2 rounded-full border border-[var(--border)] bg-[var(--bg-card)] px-3.5 py-1.5 font-mono text-xs tracking-wide text-[var(--fg-muted)] shadow-[var(--shadow)]" style="--d:0ms">
        <span class="size-2 rounded-full bg-emerald-500"></span>
        {tField(profile.location, lang)}
      </p>

      <h1 class="anim mt-6 font-display text-5xl font-light leading-[1.06] tracking-[-0.02em] sm:text-6xl lg:text-7xl" style="--d:80ms">
        Miguel Ángel
        <span class="block overflow-visible pb-[0.12em] italic text-gradient">Delgado</span>
      </h1>

      <p class="anim mt-6 max-w-xl text-lg leading-relaxed text-[var(--fg-muted)]" style="--d:160ms">
        <span class="font-medium text-[var(--fg)]">{tField(profile.role, lang)}.</span>
        {tField(profile.tagline, lang)}
      </p>

      <div class="anim mt-9" style="--d:240ms">
        <SocialButtons />
      </div>
    </div>

    <!-- Tarjeta de código -->
    <div class="anim-fade relative hidden lg:block" style="--d:200ms">
      <div class="absolute -inset-4 -z-10 rounded-[1.6rem] bg-gradient-to-br from-[var(--brand)]/20 via-[#6366f1]/10 to-transparent blur-2xl"></div>
      <div class="card overflow-hidden rounded-2xl">
        <div class="flex items-center gap-2 border-b border-[var(--border)] bg-[var(--bg-subtle)] px-4 py-3">
          <span class="size-3 rounded-full bg-[#ff5f57]"></span>
          <span class="size-3 rounded-full bg-[#febc2e]"></span>
          <span class="size-3 rounded-full bg-[#28c840]"></span>
          <span class="ml-2 font-mono text-xs text-[var(--fg-subtle)]">Developer.php</span>
        </div>
        <pre class="code overflow-x-auto p-5 font-mono text-[13px] leading-[1.7]"><code><span class="code-line"><span class="text-[var(--fg-subtle)]">&lt;?php</span></span><span class="code-line"><span class="text-[var(--code-kw)]">final class</span> <span class="text-[var(--brand)]">Developer</span> <span class="text-[var(--code-kw)]">extends</span> <span class="text-[var(--code-class)]">Human</span></span><span class="code-line">{'{'}</span><span class="code-line">  <span class="text-[var(--code-kw)]">public</span> <span class="text-[var(--code-type)]">string</span> <span class="text-[var(--code-var)]">$name</span> = <span class="text-[var(--brand)]">'Miguel A. Delgado'</span>;</span><span class="code-line">  <span class="text-[var(--code-kw)]">public</span> <span class="text-[var(--code-type)]">int</span> <span class="text-[var(--code-var)]">$years</span> = <span class="text-[var(--code-class)]">15</span>;</span><span class="code-line">  <span class="text-[var(--code-kw)]">public</span> <span class="text-[var(--code-type)]">array</span> <span class="text-[var(--code-var)]">$stack</span> = [</span><span class="code-line">    <span class="text-[var(--brand)]">'PHP'</span>, <span class="text-[var(--brand)]">'Laravel'</span>, <span class="text-[var(--brand)]">'React'</span>,</span><span class="code-line">  ];</span><span class="code-line"> </span><span class="code-line">  <span class="text-[var(--code-kw)]">public function</span> <span class="text-[var(--code-type)]">build</span>(): <span class="text-[var(--code-class)]">Quality</span></span><span class="code-line">  {'{'}</span><span class="code-line">    <span class="text-[var(--code-kw)]">return</span> <span class="text-[var(--code-var)]">$this</span>-&gt;<span class="text-[var(--code-type)]">craft</span>()-&gt;<span class="text-[var(--code-type)]">ship</span>();</span><span class="code-line">  {'}'}</span><span class="code-line">{'}'}<span class="blink text-[var(--brand)]">▋</span></span></code></pre>
      </div>
    </div>
  </div>
</section>
