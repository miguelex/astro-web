---
import PageHeader from "./PageHeader.astro";
import { getPosts, postSlug, formatDate } from "../lib/blog";
import { getLangFromUrl, useTranslations } from "../i18n/utils";

const lang = getLangFromUrl(Astro.url);
const t = useTranslations(lang);
const posts = await getPosts("es"); // el blog es siempre en español
const base = "/blog";
---

<PageHeader title={t("blog.title")} subtitle={t("blog.subtitle")} kicker="Blog" />

<div class="mx-auto max-w-3xl px-5 py-16">
  {
    posts.length === 0 ? (
      <p class="text-[var(--fg-muted)]">{t("blog.empty")}</p>
    ) : (
      <ul class="flex flex-col gap-4">
        {posts.map((post) => (
          <li class="reveal">
            <a
              href={`${base}/${postSlug(post.id)}`}
              class="group block rounded-2xl border border-[var(--border)] bg-[var(--bg-card)] p-6 transition-all hover:-translate-y-0.5 hover:border-[var(--brand)]/50 hover:shadow-[var(--shadow)]"
            >
              <div class="flex items-center gap-3 font-mono text-xs text-[var(--fg-subtle)]">
                <time datetime={post.data.pubDate.toISOString()}>
                  {formatDate(post.data.pubDate, lang)}
                </time>
                {post.data.tags.slice(0, 2).map((tag) => (
                  <span class="text-[var(--brand)]">#{tag}</span>
                ))}
              </div>
              <h2 class="mt-2.5 font-display text-2xl font-medium tracking-[-0.01em] transition-colors group-hover:text-[var(--brand)]">
                {post.data.title}
              </h2>
              <p class="mt-2 text-[var(--fg-muted)]">{post.data.description}</p>
              <span class="mt-4 inline-flex items-center gap-1.5 font-mono text-sm font-semibold text-[var(--brand)]">
                {t("blog.readmore")}
                <span class="transition-transform group-hover:translate-x-1">→</span>
              </span>
            </a>
          </li>
        ))}
      </ul>
    )
  }
</div>
