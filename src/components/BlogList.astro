---
import PageHeader from "./PageHeader.astro";
import { getPosts, postSlug, formatDate } from "../lib/blog";
import { getLangFromUrl, useTranslations } from "../i18n/utils";

const lang = getLangFromUrl(Astro.url);
const t = useTranslations(lang);
const posts = await getPosts(lang);
const base = lang === "es" ? "/blog" : "/en/blog";
---

<PageHeader title={t("blog.title")} subtitle={t("blog.subtitle")} />

<div class="mx-auto max-w-3xl px-5 py-14">
  {
    posts.length === 0 ? (
      <p class="text-[var(--fg-muted)]">{t("blog.empty")}</p>
    ) : (
      <ul class="divide-y divide-[var(--border)]">
        {posts.map((post) => (
          <li class="group py-6 first:pt-0">
            <a href={`${base}/${postSlug(post.id)}`} class="block">
              <div class="flex items-center gap-3 font-mono text-xs text-[var(--fg-subtle)]">
                <time datetime={post.data.pubDate.toISOString()}>
                  {formatDate(post.data.pubDate, lang)}
                </time>
                {post.data.tags.slice(0, 2).map((tag) => (
                  <span class="text-[var(--brand)]">#{tag}</span>
                ))}
              </div>
              <h2 class="mt-2 font-display text-xl font-bold tracking-tight transition-colors group-hover:text-[var(--brand)]">
                {post.data.title}
              </h2>
              <p class="mt-1.5 text-[var(--fg-muted)]">{post.data.description}</p>
              <span class="mt-3 inline-flex items-center gap-1 font-mono text-sm font-semibold text-[var(--brand)]">
                {t("blog.readmore")}
                <span class="transition-transform group-hover:translate-x-1">→</span>
              </span>
            </a>
          </li>
        ))}
      </ul>
    )
  }
</div>
