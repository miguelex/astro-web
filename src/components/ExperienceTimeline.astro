---
import { experience } from "../data";
import { getLangFromUrl, useTranslations, tField } from "../i18n/utils";
import TechTag from "./TechTag.astro";
const lang = getLangFromUrl(Astro.url);
const t = useTranslations(lang);
---

<ol class="relative ml-1 border-l border-[var(--border)] pl-7 sm:pl-9">
  {
    experience.map((job) => (
      <li class="reveal relative mb-12 last:mb-0">
        <span class="absolute -left-[2.05rem] top-1 grid place-items-center sm:-left-[2.55rem]">
          <span class="size-3.5 rounded-full border-2 border-[var(--brand)] bg-[var(--bg)] shadow-[0_0_0_4px_var(--bg)]" />
        </span>
        <div class="flex flex-wrap items-baseline justify-between gap-x-4 gap-y-1">
          <h3 class="font-display text-xl font-medium">{tField(job.role, lang)}</h3>
          <span class="rounded-md bg-[var(--bg-subtle)] px-2 py-0.5 font-mono text-xs text-[var(--brand)]">
            {job.start} — {job.end ?? t("present")}
          </span>
        </div>
        <p class="mt-1 text-sm font-medium text-[var(--fg-muted)]">
          {job.company} · {tField(job.location, lang)}
        </p>
        <p class="mt-3.5 text-sm leading-relaxed text-[var(--fg-muted)]">
          {tField(job.description, lang)}
        </p>
        <ul class="mt-3.5 space-y-1.5">
          {tField(job.highlights, lang).map((h) => (
            <li class="flex gap-2.5 text-sm text-[var(--fg-muted)]">
              <span class="mt-[0.15rem] text-[var(--brand)]" aria-hidden="true">
                ▹
              </span>
              <span>{h}</span>
            </li>
          ))}
        </ul>
        <ul class="mt-4 flex flex-wrap gap-1.5">
          {job.tech.map((tag) => (
            <TechTag name={tag} size="sm" />
          ))}
        </ul>
      </li>
    ))
  }
</ol>
