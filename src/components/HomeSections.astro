---
import Hero from "./Hero.astro";
import SectionHeading from "./SectionHeading.astro";
import SkillsGrid from "./SkillsGrid.astro";
import ExperienceTimeline from "./ExperienceTimeline.astro";
import EducationList from "./EducationList.astro";
import ProjectCard from "./ProjectCard.astro";
import { featuredProjects } from "../data";
import { getLangFromUrl, useTranslations } from "../i18n/utils";

const lang = getLangFromUrl(Astro.url);
const t = useTranslations(lang);
const allProjects = lang === "es" ? "/proyectos" : "/en/projects";
---

<Hero />

<div class="mx-auto max-w-5xl space-y-24 px-5 pb-8">
  <section aria-labelledby="skills">
    <SectionHeading index="01" id="skills" title={t("section.skills")} />
    <SkillsGrid />
  </section>

  <section aria-labelledby="experience">
    <SectionHeading index="02" id="experience" title={t("section.experience")} />
    <ExperienceTimeline />
  </section>

  <section aria-labelledby="education">
    <SectionHeading index="03" id="education" title={t("section.education")} />
    <EducationList />
  </section>

  <section aria-labelledby="projects">
    <SectionHeading index="04" id="projects" title={t("section.projects")} />
    <div class="grid gap-6 sm:grid-cols-2 lg:grid-cols-3">
      {featuredProjects.map((project) => <ProjectCard project={project} />)}
    </div>
    <div class="mt-8">
      <a
        href={allProjects}
        class="group inline-flex items-center gap-2 font-mono text-sm font-semibold text-[var(--brand)]"
      >
        {t("section.projects.all")}
        <span class="transition-transform group-hover:translate-x-1">→</span>
      </a>
    </div>
  </section>
</div>
