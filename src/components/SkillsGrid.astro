---
import { skills } from "../data";
import { getLangFromUrl, useTranslations } from "../i18n/utils";
import type { UIKey } from "../i18n/ui";
import { techIconPath } from "../lib/techIcons";
const lang = getLangFromUrl(Astro.url);
const t = useTranslations(lang);

type Cat = "tech" | "tools" | "databases" | "soft";
const meta: Record<Cat, { key: UIKey; n: string; color: string; icon: string }> = {
  tech: {
    key: "section.skills.tech",
    n: "01",
    color: "#38bdf8",
    icon: "M8 6 2 12l6 6M16 6l6 6-6 6M14 4l-4 16",
  },
  tools: {
    key: "section.skills.tools",
    n: "02",
    color: "#2dd4bf",
    icon: "M14.7 6.3a4 4 0 0 0-5.4 5.4L3 18l3 3 6.3-6.3a4 4 0 0 0 5.4-5.4l-2.6 2.6-2.4-.6-.6-2.4 2.6-2.6Z",
  },
  databases: {
    key: "section.skills.databases",
    n: "03",
    color: "#f59e0b",
    icon: "M12 3c4.4 0 8 1.3 8 3s-3.6 3-8 3-8-1.3-8-3 3.6-3 8-3ZM4 6v12c0 1.7 3.6 3 8 3s8-1.3 8-3V6M4 12c0 1.7 3.6 3 8 3s8-1.3 8-3",
  },
  soft: {
    key: "section.skills.soft",
    n: "04",
    color: "#a78bfa",
    icon: "M17 21v-2a4 4 0 0 0-4-4H5a4 4 0 0 0-4 4v2M9 11a4 4 0 1 0 0-8 4 4 0 0 0 0 8ZM23 21v-2a4 4 0 0 0-3-3.9M16 3.1a4 4 0 0 1 0 7.8",
  },
};
---

<div class="grid gap-5 sm:grid-cols-2">
  {
    skills.map((group) => {
      const m = meta[group.category as Cat];
      return (
        <div
          class="reveal group relative overflow-hidden rounded-2xl border border-[var(--border)] bg-[var(--bg-card)] p-6 transition-all duration-300 hover:-translate-y-1 hover:shadow-[var(--shadow)]"
          style={`--cat:${m.color}`}
        >
          <div
            class="pointer-events-none absolute -right-16 -top-16 size-40 rounded-full opacity-0 blur-2xl transition-opacity duration-500 group-hover:opacity-100"
            style="background: radial-gradient(circle, var(--cat), transparent 70%)"
          />
          <div
            class="absolute inset-x-0 top-0 h-px opacity-70"
            style="background: linear-gradient(90deg, var(--cat), transparent)"
          />

          <div class="mb-5 flex items-center gap-3">
            <span
              class="grid size-10 place-items-center rounded-xl border"
              style="color: var(--cat); border-color: color-mix(in srgb, var(--cat) 35%, transparent); background: color-mix(in srgb, var(--cat) 12%, transparent)"
            >
              <svg class="size-5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                <path d={m.icon} />
              </svg>
            </span>
            <h3 class="font-display text-lg font-medium">{t(m.key)}</h3>
            <span class="ml-auto font-mono text-xs" style="color: var(--cat)">
              {m.n}
            </span>
          </div>

          <ul class="flex flex-wrap gap-2">
            {group.items.map((item) => {
              const iconPath = techIconPath(item);
              return (
                <li
                  class="skill-badge inline-flex items-center gap-1.5 rounded-lg border px-2.5 py-1.5 text-sm font-medium transition-all duration-200 hover:-translate-y-0.5 hover:shadow-sm"
                  style="color: color-mix(in srgb, var(--cat) 88%, var(--fg)); border-color: color-mix(in srgb, var(--cat) 30%, transparent); background: color-mix(in srgb, var(--cat) 9%, transparent)"
                >
                  {iconPath ? (
                    <svg class="size-3.5 opacity-90" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
                      <path d={iconPath} />
                    </svg>
                  ) : (
                    <span class="size-1.5 rounded-full bg-current opacity-50" aria-hidden="true" />
                  )}
                  {item}
                </li>
              );
            })}
          </ul>
        </div>
      );
    })
  }
</div>
