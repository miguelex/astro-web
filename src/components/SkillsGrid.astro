---
import { skills } from "../data";
import { getLangFromUrl, useTranslations } from "../i18n/utils";
import type { UIKey } from "../i18n/ui";
const lang = getLangFromUrl(Astro.url);
const t = useTranslations(lang);

const labelKey: Record<string, UIKey> = {
  tech: "section.skills.tech",
  tools: "section.skills.tools",
  databases: "section.skills.databases",
  soft: "section.skills.soft",
};
---

<div class="grid gap-5 sm:grid-cols-2">
  {
    skills.map((group) => (
      <div class="rounded-2xl border border-[var(--border)] bg-[var(--bg-card)] p-6 transition-colors hover:border-[var(--brand)]">
        <h3 class="mb-4 font-mono text-sm font-semibold uppercase tracking-wider text-[var(--fg-subtle)]">
          {t(labelKey[group.category])}
        </h3>
        <ul class="flex flex-wrap gap-2">
          {group.items.map((item) => (
            <li class="rounded-lg border border-[var(--border)] bg-[var(--bg-subtle)] px-3 py-1.5 text-sm text-[var(--fg-muted)]">
              {item}
            </li>
          ))}
        </ul>
      </div>
    ))
  }
</div>
