---
/**
 * Fondo vivo para toda la web: tres "auroras" de color que derivan lentamente,
 * unas partículas flotantes y una capa de grano. Es decorativo (aria-hidden) y
 * se sitúa por detrás de todo el contenido. Respeta prefers-reduced-motion vía
 * las clases definidas en global.css.
 */
const dots = [
  { top: "18%", left: "12%", size: 7, delay: "0s" },
  { top: "32%", left: "82%", size: 5, delay: "1.5s" },
  { top: "64%", left: "24%", size: 6, delay: "3s" },
  { top: "72%", left: "70%", size: 4, delay: "0.8s" },
  { top: "46%", left: "50%", size: 5, delay: "2.2s" },
];
---

<div class="site-bg" aria-hidden="true">
  <div class="aurora aurora-a"></div>
  <div class="aurora aurora-b"></div>
  <div class="aurora aurora-c"></div>
  {
    dots.map((d) => (
      <span
        class="floaty float-dot"
        style={`top:${d.top};left:${d.left};width:${d.size}px;height:${d.size}px;animation-delay:${d.delay}`}
      />
    ))
  }
  <div class="grain"></div>
</div>
