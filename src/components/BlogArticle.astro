---
import type { Post } from "../lib/blog";
import { formatDate } from "../lib/blog";
import { getLangFromUrl, useTranslations } from "../i18n/utils";

interface Props {
  post: Post;
}
const { post } = Astro.props;
const lang = getLangFromUrl(Astro.url);
const t = useTranslations(lang);
---

<article class="mx-auto max-w-2xl px-5 py-16">
  <a
    href="/blog"
    class="group inline-flex items-center gap-1.5 font-mono text-sm text-[var(--fg-muted)] transition-colors hover:text-[var(--brand)]"
  >
    <span class="inline-block transition-transform group-hover:-translate-x-1">←</span>
    {t("blog.back")}
  </a>

  <header class="anim mt-8 border-b border-[var(--border)] pb-8" style="--d:60ms">
    <div class="flex flex-wrap items-center gap-3 font-mono text-xs text-[var(--fg-subtle)]">
      <time datetime={post.data.pubDate.toISOString()}>
        {formatDate(post.data.pubDate, lang)}
      </time>
      {post.data.tags.map((tag) => <span class="text-[var(--brand)]">#{tag}</span>)}
    </div>
    <h1 class="mt-3.5 font-display text-4xl font-light leading-[1.05] tracking-[-0.02em] sm:text-5xl">
      {post.data.title}
    </h1>
    <p class="mt-4 text-lg leading-relaxed text-[var(--fg-muted)]">{post.data.description}</p>
  </header>

  <div class="prose anim mt-9" style="--d:140ms">
    <slot />
  </div>
</article>
