---
import type { Project } from "../types";
import { getLangFromUrl, useTranslations, tField } from "../i18n/utils";

interface Props {
  project: Project;
}
const { project } = Astro.props;
const lang = getLangFromUrl(Astro.url);
const t = useTranslations(lang);
---

<article
  class="reveal group relative flex flex-col overflow-hidden rounded-2xl border border-[var(--border)] bg-[var(--bg-card)] transition-all duration-300 hover:-translate-y-1.5 hover:border-[var(--brand)]/60 hover:shadow-[0_20px_50px_-12px_var(--glow)]"
>
  <!-- línea de acento superior que aparece al hover -->
  <div class="absolute inset-x-0 top-0 z-10 h-0.5 origin-left scale-x-0 bg-gradient-to-r from-[var(--brand)] via-[#e2725b] to-transparent transition-transform duration-500 group-hover:scale-x-100"></div>

  <div class="relative aspect-[16/10] overflow-hidden">
    <img
      src={project.image}
      alt={tField(project.title, lang)}
      loading="lazy"
      decoding="async"
      width="800"
      height="500"
      class="size-full object-cover transition-transform duration-700 ease-out group-hover:scale-[1.06]"
    />
    <span
      class="absolute left-3 top-3 rounded-md border border-white/10 bg-black/40 px-2 py-1 font-mono text-[11px] text-white/80 backdrop-blur-sm"
    >
      {project.year}
    </span>
  </div>

  <div class="flex flex-1 flex-col border-t border-[var(--border)] p-6">
    <h3 class="font-display text-xl font-medium tracking-[-0.01em] transition-colors group-hover:text-[var(--brand)]">
      {tField(project.title, lang)}
    </h3>
    <p class="mt-2.5 flex-1 text-sm leading-relaxed text-[var(--fg-muted)]">
      {tField(project.description, lang)}
    </p>

    <ul class="mt-4 flex flex-wrap gap-1.5">
      {
        project.tech.map((tag) => (
          <li class="rounded-md border border-[var(--brand)]/20 bg-[var(--brand)]/[0.07] px-2 py-0.5 font-mono text-[11px] text-[var(--brand)]">
            {tag}
          </li>
        ))
      }
    </ul>

    <div class="mt-5 flex items-center gap-4 border-t border-[var(--border)] pt-4">
      {
        project.repo ? (
          <a
            href={project.repo}
            target="_blank"
            rel="noopener noreferrer"
            class="inline-flex items-center gap-1.5 text-sm font-semibold text-[var(--fg-muted)] transition-colors hover:text-[var(--brand)]"
          >
            <svg class="size-4" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
              <path d="M12 .5C5.7.5.5 5.7.5 12c0 5.1 3.3 9.4 7.9 10.9.6.1.8-.2.8-.6v-2c-3.2.7-3.9-1.5-3.9-1.5-.5-1.3-1.3-1.7-1.3-1.7-1-.7.1-.7.1-.7 1.2.1 1.8 1.2 1.8 1.2 1 1.8 2.7 1.3 3.4 1 .1-.8.4-1.3.7-1.6-2.6-.3-5.3-1.3-5.3-5.7 0-1.3.5-2.3 1.2-3.1-.1-.3-.5-1.5.1-3.1 0 0 1-.3 3.3 1.2a11.5 11.5 0 0 1 6 0C17.3 4.7 18.3 5 18.3 5c.6 1.6.2 2.8.1 3.1.8.8 1.2 1.8 1.2 3.1 0 4.4-2.7 5.4-5.3 5.7.4.4.8 1.1.8 2.2v3.3c0 .4.2.7.8.6 4.6-1.5 7.9-5.8 7.9-10.9C23.5 5.7 18.3.5 12 .5z" />
            </svg>
            {t("project.repo")}
          </a>
        ) : (
          <span class="inline-flex items-center gap-1.5 font-mono text-xs text-[var(--fg-subtle)]">
            <svg class="size-3.5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true">
              <rect x="3" y="11" width="18" height="11" rx="2" />
              <path d="M7 11V7a5 5 0 0 1 10 0v4" />
            </svg>
            {t("project.private")}
          </span>
        )
      }
      {
        project.demo && (
          <a
            href={project.demo}
            target="_blank"
            rel="noopener noreferrer"
            class="group/d ml-auto inline-flex items-center gap-1.5 text-sm font-semibold text-[var(--brand)] transition-colors"
          >
            {t("project.demo")}
            <svg class="size-4 transition-transform group-hover/d:translate-x-0.5 group-hover/d:-translate-y-0.5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
              <path d="M7 17L17 7M7 7h10v10" />
            </svg>
          </a>
        )
      }
    </div>
  </div>
</article>
