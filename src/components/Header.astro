---
import Logo from "./Logo.astro";
import ThemeToggle from "./ThemeToggle.astro";
import LangToggle from "./LangToggle.astro";
import { getLangFromUrl, useTranslations } from "../i18n/utils";
import { profile } from "../data";

const lang = getLangFromUrl(Astro.url);
const t = useTranslations(lang);
const home = lang === "es" ? "/" : "/en";

// El blog es siempre en español (/blog) desde ambos idiomas.
const nav =
  lang === "es"
    ? [
        { href: "/proyectos", key: "nav.projects" as const },
        { href: "/certificaciones", key: "nav.certifications" as const },
        { href: "/blog", key: "nav.blog" as const },
      ]
    : [
        { href: "/en/projects", key: "nav.projects" as const },
        { href: "/en/certifications", key: "nav.certifications" as const },
        { href: "/blog", key: "nav.blog" as const },
      ];

const path = Astro.url.pathname.replace(/\/$/, "");
const isActive = (href: string) => {
  const h = href.replace(/\/$/, "");
  return path === h || (h !== home.replace(/\/$/, "") && path.startsWith(h));
};
---

<header
  class="site-header sticky top-0 z-50 border-b border-[var(--border)] bg-[color-mix(in_srgb,var(--bg)_80%,transparent)] backdrop-blur-xl"
>
  <div class="mx-auto flex h-16 max-w-5xl items-center justify-between gap-4 px-5">
    <a href={home} class="group flex items-center gap-2.5">
      <Logo size={34} decorative class="transition-transform duration-300 group-hover:rotate-[-6deg]" />
      <span class="font-display text-lg font-medium tracking-tight">
        Miguel <span class="italic text-[var(--brand)]">Delgado</span>
      </span>
    </a>

    <nav class="hidden items-center gap-1 md:flex" aria-label={t("nav.menu")}>
      {
        nav.map((item) => (
          <a
            href={item.href}
            class:list={[
              "relative rounded-lg px-3 py-2 text-sm font-medium transition-colors hover:text-[var(--brand)]",
              isActive(item.href) ? "text-[var(--brand)]" : "text-[var(--fg-muted)]",
            ]}
          >
            {t(item.key)}
          </a>
        ))
      }
      <span class="mx-1 h-5 w-px bg-[var(--border)]"></span>
      <a
        href={lang === "es" ? "/cv" : "/en/cv"}
        class="rounded-lg border border-[var(--border-strong)] px-3 py-1.5 text-sm font-medium transition-colors hover:border-[var(--brand)] hover:text-[var(--brand)]"
      >
        {t("nav.cv")}
      </a>
    </nav>

    <div class="flex items-center gap-2">
      <a
        href={profile.social.github}
        target="_blank"
        rel="noopener noreferrer"
        class="hidden size-9 place-items-center rounded-lg border border-[var(--border)] bg-[var(--bg-card)] text-[var(--fg-muted)] transition-colors hover:border-[var(--brand)] hover:text-[var(--brand)] sm:grid"
        aria-label="GitHub"
        title="GitHub"
      >
        <svg class="size-[18px]" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
          <path d="M12 .5C5.7.5.5 5.7.5 12c0 5.1 3.3 9.4 7.9 10.9.6.1.8-.2.8-.6v-2c-3.2.7-3.9-1.5-3.9-1.5-.5-1.3-1.3-1.7-1.3-1.7-1-.7.1-.7.1-.7 1.2.1 1.8 1.2 1.8 1.2 1 1.8 2.7 1.3 3.4 1 .1-.8.4-1.3.7-1.6-2.6-.3-5.3-1.3-5.3-5.7 0-1.3.5-2.3 1.2-3.1-.1-.3-.5-1.5.1-3.1 0 0 1-.3 3.3 1.2a11.5 11.5 0 0 1 6 0C17.3 4.7 18.3 5 18.3 5c.6 1.6.2 2.8.1 3.1.8.8 1.2 1.8 1.2 3.1 0 4.4-2.7 5.4-5.3 5.7.4.4.8 1.1.8 2.2v3.3c0 .4.2.7.8.6 4.6-1.5 7.9-5.8 7.9-10.9C23.5 5.7 18.3.5 12 .5z"></path>
        </svg>
      </a>
      <a
        href={profile.social.linkedin}
        target="_blank"
        rel="noopener noreferrer"
        class="hidden size-9 place-items-center rounded-lg border border-[var(--border)] bg-[var(--bg-card)] text-[var(--fg-muted)] transition-colors hover:border-[var(--brand)] hover:text-[var(--brand)] sm:grid"
        aria-label="LinkedIn"
        title="LinkedIn"
      >
        <svg class="size-[18px]" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
          <path d="M20.45 20.45h-3.55v-5.57c0-1.33 0-3.04-1.85-3.04-1.85 0-2.13 1.45-2.13 2.94v5.67H9.35V9h3.41v1.56h.05c.48-.9 1.64-1.85 3.37-1.85 3.6 0 4.27 2.37 4.27 5.46v6.28zM5.34 7.43a2.06 2.06 0 1 1 0-4.12 2.06 2.06 0 0 1 0 4.12zM7.12 20.45H3.56V9h3.56v11.45zM22.22 0H1.77C.79 0 0 .77 0 1.73v20.54C0 23.22.79 24 1.77 24h20.45c.98 0 1.78-.78 1.78-1.73V1.73C24 .77 23.2 0 22.22 0z"></path>
        </svg>
      </a>
      <span class="mx-0.5 hidden h-5 w-px bg-[var(--border)] sm:block"></span>
      <LangToggle />
      <ThemeToggle />
      <button
        id="menu-toggle"
        type="button"
        class="grid size-9 place-items-center rounded-lg border border-[var(--border)] bg-[var(--bg-card)] text-[var(--fg-muted)] md:hidden"
        aria-label={t("nav.menu")}
        aria-expanded="false"
        aria-controls="mobile-nav"
      >
        <svg class="size-5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" aria-hidden="true">
          <path d="M4 6h16M4 12h16M4 18h16"></path>
        </svg>
      </button>
    </div>
  </div>

  <nav
    id="mobile-nav"
    class="hidden border-t border-[var(--border)] bg-[var(--bg)] px-5 py-3 md:hidden"
    aria-label={t("nav.menu")}
  >
    {
      [...nav, { href: lang === "es" ? "/cv" : "/en/cv", key: "nav.cv" as const }].map((item) => (
        <a
          href={item.href}
          class="block rounded-lg px-3 py-2.5 text-sm font-medium text-[var(--fg-muted)] hover:bg-[var(--bg-subtle)] hover:text-[var(--brand)]"
        >
          {t(item.key)}
        </a>
      ))
    }
  </nav>
</header>

<script is:inline>
  (() => {
    const btn = document.getElementById("menu-toggle");
    const menu = document.getElementById("mobile-nav");
    btn?.addEventListener("click", () => {
      const open = menu?.classList.toggle("hidden");
      btn.setAttribute("aria-expanded", String(open === false));
    });
  })();
</script>
