---
import { getLangFromUrl, alternateUrl, useTranslations } from "../i18n/utils";
const lang = getLangFromUrl(Astro.url);
const t = useTranslations(lang);
const target = lang === "es" ? "en" : "es";

// El blog solo existe en español. Si estamos en una ruta de blog y cambiamos a
// inglés, no hay equivalente: llevamos a la home inglesa.
const path = Astro.url.pathname;
const href = target === "en" && path.startsWith("/blog") ? "/en" : alternateUrl(Astro.url, target);
---

<a
  href={href}
  class="grid h-9 place-items-center rounded-lg border border-[var(--border)] bg-[var(--bg-card)] px-3 font-mono text-xs font-semibold uppercase tracking-wide text-[var(--fg-muted)] transition-colors hover:border-[var(--brand)] hover:text-[var(--brand)]"
  aria-label={t("lang.toggle")}
  title={t("lang.toggle")}
>
  {target}
</a>
