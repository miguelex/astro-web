---
import { getLangFromUrl, alternateUrl, useTranslations } from "../i18n/utils";
const lang = getLangFromUrl(Astro.url);
const t = useTranslations(lang);
const target = lang === "es" ? "en" : "es";

// Rutas cuyo slug difiere entre idiomas (no sirve el mapeo genérico).
const slugMap: Record<string, string> = {
  "/aviso-legal": "/en/legal-notice",
  "/en/legal-notice": "/aviso-legal",
  "/privacidad": "/en/privacy",
  "/en/privacy": "/privacidad",
};

const path = Astro.url.pathname.replace(/\/$/, "") || "/";
let href: string;
if (slugMap[path]) {
  href = slugMap[path];
} else if (target === "en" && path.startsWith("/blog")) {
  // El blog solo existe en español; al pasar a inglés vamos a la home inglesa.
  href = "/en";
} else {
  href = alternateUrl(Astro.url, target);
}
---

<a
  href={href}
  class="grid h-9 place-items-center rounded-lg border border-[var(--border)] bg-[var(--bg-card)] px-3 font-mono text-xs font-semibold uppercase tracking-wide text-[var(--fg-muted)] transition-colors hover:border-[var(--brand)] hover:text-[var(--brand)]"
  aria-label={`${t("lang.toggle")} (${target.toUpperCase()})`}
  title={t("lang.toggle")}
>
  {target}
</a>
