---
import { getLangFromUrl, useTranslations } from "../i18n/utils";
const lang = getLangFromUrl(Astro.url);
const t = useTranslations(lang);
const target = lang === "es" ? "en" : "es";

// Rutas cuyo primer segmento (slug) difiere entre idiomas. El resto de
// segmentos (nº de página, slug de post...) se conserva tal cual.
const slugByEn: Record<string, string> = {
  proyectos: "projects",
  certificaciones: "certifications",
  "aviso-legal": "legal-notice",
  privacidad: "privacy",
};
const slugByEs: Record<string, string> = Object.fromEntries(
  Object.entries(slugByEn).map(([es, en]) => [en, es]),
);

// Segmentos en idioma "neutro" (sin el prefijo /en).
const segments = Astro.url.pathname.split("/").filter(Boolean);
if (lang === "en") segments.shift();

let href: string;
if (target === "en" && segments[0] === "blog") {
  // El blog solo existe en español; al pasar a inglés vamos a la home inglesa.
  href = "/en/";
} else {
  // Traduce el primer segmento si tiene equivalente en el idioma destino.
  const translated = [...segments];
  if (translated[0]) {
    const map = target === "en" ? slugByEn : slugByEs;
    translated[0] = map[translated[0]] ?? translated[0];
  }
  const prefix = target === "en" ? "/en" : "";
  const path = translated.join("/");
  href = path ? `${prefix}/${path}/` : `${prefix}/`;
}
---

<a
  href={href}
  class="grid h-9 place-items-center rounded-lg border border-[var(--border)] bg-[var(--bg-card)] px-3 font-mono text-xs font-semibold uppercase tracking-wide text-[var(--fg-muted)] transition-colors hover:border-[var(--brand)] hover:text-[var(--brand)]"
  aria-label={`${t("lang.toggle")} (${target.toUpperCase()})`}
  title={t("lang.toggle")}
>
  {target}
</a>
