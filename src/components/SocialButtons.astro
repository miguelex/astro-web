---
import { profile } from "../data";
import { getLangFromUrl, useTranslations } from "../i18n/utils";
const lang = getLangFromUrl(Astro.url);
const t = useTranslations(lang);
// El PDF real solo existe tras `npm run build` (lo genera Playwright). En dev
// ese archivo no está, así que el botón abre la página imprimible como fallback.
const cvPdf = lang === "es" ? "/cv.pdf" : "/cv.en.pdf";
const cvPreview = lang === "es" ? "/cv-pdf" : "/en/cv-pdf";
const cvHref = import.meta.env.PROD ? cvPdf : cvPreview;
---

<div class="flex flex-wrap items-center gap-3">
  <a
    href={cvHref}
    download={import.meta.env.PROD}
    class="group inline-flex items-center gap-2 rounded-xl bg-[var(--brand)] px-5 py-3 text-sm font-semibold text-[var(--brand-fg)] shadow-[var(--shadow)] transition-all hover:-translate-y-0.5 hover:shadow-lg"
  >
    <svg class="size-4 transition-transform group-hover:translate-y-0.5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
      <path d="M21 15v4a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2v-4M7 10l5 5 5-5M12 15V3"></path>
    </svg>
    {t("hero.cta.cv")}
  </a>

  <a
    href={profile.social.linkedin}
    target="_blank"
    rel="noopener noreferrer"
    class="inline-flex items-center gap-2 rounded-xl border border-[var(--border-strong)] bg-[var(--bg-card)] px-5 py-3 text-sm font-semibold transition-colors hover:border-[var(--brand)] hover:text-[var(--brand)]"
  >
    <svg class="size-4" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
      <path d="M20.45 20.45h-3.55v-5.57c0-1.33 0-3.04-1.85-3.04-1.85 0-2.13 1.45-2.13 2.94v5.67H9.35V9h3.41v1.56h.05c.48-.9 1.64-1.85 3.37-1.85 3.6 0 4.27 2.37 4.27 5.46v6.28zM5.34 7.43a2.06 2.06 0 1 1 0-4.12 2.06 2.06 0 0 1 0 4.12zM7.12 20.45H3.56V9h3.56v11.45zM22.22 0H1.77C.79 0 0 .77 0 1.73v20.54C0 23.22.79 24 1.77 24h20.45c.98 0 1.78-.78 1.78-1.73V1.73C24 .77 23.2 0 22.22 0z"></path>
    </svg>
    {t("hero.cta.linkedin")}
  </a>

  <a
    href={profile.social.github}
    target="_blank"
    rel="noopener noreferrer"
    class="grid size-11 place-items-center rounded-xl border border-[var(--border-strong)] bg-[var(--bg-card)] transition-colors hover:border-[var(--brand)] hover:text-[var(--brand)]"
    aria-label={t("hero.cta.github")}
    title={t("hero.cta.github")}
  >
    <svg class="size-5" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
      <path d="M12 .5C5.7.5.5 5.7.5 12c0 5.1 3.3 9.4 7.9 10.9.6.1.8-.2.8-.6v-2c-3.2.7-3.9-1.5-3.9-1.5-.5-1.3-1.3-1.7-1.3-1.7-1-.7.1-.7.1-.7 1.2.1 1.8 1.2 1.8 1.2 1 1.8 2.7 1.3 3.4 1 .1-.8.4-1.3.7-1.6-2.6-.3-5.3-1.3-5.3-5.7 0-1.3.5-2.3 1.2-3.1-.1-.3-.5-1.5.1-3.1 0 0 1-.3 3.3 1.2a11.5 11.5 0 0 1 6 0C17.3 4.7 18.3 5 18.3 5c.6 1.6.2 2.8.1 3.1.8.8 1.2 1.8 1.2 3.1 0 4.4-2.7 5.4-5.3 5.7.4.4.8 1.1.8 2.2v3.3c0 .4.2.7.8.6 4.6-1.5 7.9-5.8 7.9-10.9C23.5 5.7 18.3.5 12 .5z"></path>
    </svg>
  </a>
</div>
