---
import { getLangFromUrl, alternateUrl } from "../i18n/utils";

interface Props {
  title: string;
  description: string;
  image?: string;
  noindex?: boolean;
  type?: "website" | "article";
}
const {
  title,
  description,
  image = "/og/default.png",
  noindex = false,
  type = "website",
} = Astro.props;

const lang = getLangFromUrl(Astro.url);
const site = Astro.site ?? new URL("http://localhost:4321");
const canonical = new URL(Astro.url.pathname, site).href;
const ogImage = new URL(image, site).href;

const esHref = new URL(alternateUrl(Astro.url, "es"), site).href;
const enHref = new URL(alternateUrl(Astro.url, "en"), site).href;
---

<title>{title}</title>
<meta name="description" content={description} />
<link rel="canonical" href={canonical} />
{noindex && <meta name="robots" content="noindex, nofollow" />}

<!-- hreflang -->
<link rel="alternate" hreflang="es" href={esHref} />
<link rel="alternate" hreflang="en" href={enHref} />
<link rel="alternate" hreflang="x-default" href={esHref} />

<!-- Open Graph -->
<meta property="og:type" content={type} />
<meta property="og:title" content={title} />
<meta property="og:description" content={description} />
<meta property="og:url" content={canonical} />
<meta property="og:image" content={ogImage} />
<meta property="og:locale" content={lang === "es" ? "es_ES" : "en_US"} />
<meta property="og:site_name" content="Miguel Ángel Delgado" />

<!-- Twitter -->
<meta name="twitter:card" content="summary_large_image" />
<meta name="twitter:title" content={title} />
<meta name="twitter:description" content={description} />
<meta name="twitter:image" content={ogImage} />
