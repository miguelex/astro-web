---
interface Props {
  title: string;
  subtitle?: string;
}
const { title, subtitle } = Astro.props;
---

<header class="border-b border-[var(--border)] bg-[var(--bg-subtle)]">
  <div class="mx-auto max-w-5xl px-5 py-16 sm:py-20">
    <span class="font-mono text-sm text-[var(--brand)]">// </span>
    <h1 class="mt-2 font-display text-4xl font-bold tracking-tight sm:text-5xl">
      {title}
    </h1>
    {subtitle && <p class="mt-4 max-w-2xl text-lg text-[var(--fg-muted)]">{subtitle}</p>}
  </div>
</header>
