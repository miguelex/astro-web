---
import type { Page } from "astro";
import type { Project } from "../types";
import PageHeader from "./PageHeader.astro";
import ProjectCard from "./ProjectCard.astro";
import Pagination from "./Pagination.astro";
import { getLangFromUrl, useTranslations } from "../i18n/utils";

interface Props {
  page: Page<Project>;
  base: string;
}
const { page, base } = Astro.props;
const lang = getLangFromUrl(Astro.url);
const t = useTranslations(lang);
---

<PageHeader title={t("projects.title")} subtitle={t("projects.subtitle")} kicker={t("kicker.work")} />

<div class="mx-auto max-w-5xl px-5 py-16">
  <div class="grid gap-6 sm:grid-cols-2 lg:grid-cols-3">
    {page.data.map((project) => <ProjectCard project={project} />)}
  </div>
  <Pagination page={page} base={base} />
</div>
